# Auth0 token verification (see ADR 0021)
# Issuer: your Auth0 tenant URL, trailing slash included. JWKS is derived as ${AUTH0_ISSUER}.well-known/jwks.json
AUTH0_ISSUER=https://your-tenant.eu.auth0.com/
# Audience: the API identifier created in the Auth0 dashboard
AUTH0_AUDIENCE=https://api.market-miam

# Cloudinary signed uploads (vendor photo uploads)
# From the Cloudinary dashboard -> Account Details. api_secret is confidential;
# cloud_name and api_key are exposed to the browser in the signed upload payload.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Postgres event store (see ADR 0029). Local dev: `docker compose up -d` starts
# pg 18 (docker-compose.yml); prod injects this from the Render database.
DATABASE_CONNECTION_STRING=postgres://marketmiam:marketmiam@localhost:5432/marketmiam

# Optional: connection-pool size per api instance (default 10). Size under the DB's
# connection cap — each instance also holds one dedicated LISTEN client.
# DATABASE_POOL_MAX=10

MASTER_KEY=32_bytes_of_randomness
