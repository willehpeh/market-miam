{
  "name": "vendor-frontend",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/vendor-frontend/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/vendor-frontend",
        "browser": "apps/vendor-frontend/src/main.ts",
        "tsConfig": "apps/vendor-frontend/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/vendor-frontend/public"
          }
        ],
        "styles": ["apps/vendor-frontend/src/styles.css"]
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/vendor-frontend/src/environments/environment.ts",
              "with": "apps/vendor-frontend/src/environments/environment.development.ts"
            }
          ]
        },
        "testing": {
          "optimization": false,
          "sourceMap": true,
          "fileReplacements": [
            {
              "replace": "apps/vendor-frontend/src/environments/environment.ts",
              "with": "apps/vendor-frontend/src/environments/environment.testing.ts"
            }
          ]
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "vendor-frontend:build:production"
        },
        "development": {
          "buildTarget": "vendor-frontend:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "buildTarget": "vendor-frontend:build:testing",
        "watch": false,
        "coverage": true,
        "coverageInclude": ["src/**/*.ts"],
        "coverageExclude": [
          "src/**/*.spec.ts",
          "src/main.ts",
          "src/**/*.config.ts"
        ],
        "coverageReporters": ["text-summary", "html", "lcov"]
      },
      "configurations": {
        "watch": {
          "watch": true
        }
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "vendor-frontend:build",
        "port": 4200,
        "staticFilePath": "dist/apps/vendor-frontend/browser",
        "spa": true
      }
    }
  }
}
