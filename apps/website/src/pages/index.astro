---
import Base from '../layouts/Base.astro';
---

<Base title="Market Miam — Bientôt disponible">
  <main>
    <h1>Market Miam</h1>
    <p>Votre étal, en ligne.</p>
    <p class="soon">Bientôt disponible</p>
  </main>
</Base>

<style>
  main {
    text-align: center;
    padding: 2rem;
  }

  h1 {
    font-size: 3rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  p {
    font-size: 1.25rem;
    color: var(--mm-ink-soft);
  }

  .soon {
    margin-top: 2rem;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--mm-muted);
  }
</style>
