{
  "name": "market-monster-api-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "implicitDependencies": ["market-monster-api"],
  "targets": {
    "e2e": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{e2eProjectRoot}"],
      "options": {
        "jestConfig": "apps/market-monster-api-e2e/jest.config.cts",
        "passWithNoTests": true
      },
      "dependsOn": ["market-monster-api:build", "market-monster-api:serve"]
    }
  }
}
