{
  "name": "test",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "test/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "typecheck": {},
    "test:coverage": {
      "command": "vitest run --coverage",
      "options": {
        "cwd": "test"
      }
    },
    "test:container": {
      "command": "vitest run --config vitest.container.config.mts",
      "options": {
        "cwd": "test"
      }
    },
    "test:container:watch": {
      "command": "vitest run --config vitest.container.config.mts --watch",
      "options": {
        "cwd": "test"
      }
    },
    "test:watch": {
      "command": "vitest run --watch",
      "options": {
        "cwd": "test"
      }
    },
    "mutation": {
      "command": "stryker run",
      "options": {
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
